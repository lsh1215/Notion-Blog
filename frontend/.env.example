# Notion API
# https://www.notion.so/my-integrations 에서 생성
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database IDs
# 블로그 데이터베이스 URL에서 추출: notion.so/{workspace}/{database_id}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 포트폴리오 데이터베이스 ID (별도 데이터베이스 사용 시)
NOTION_PORTFOLIO_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# On-Demand Revalidation
# 캐시 즉시 갱신 API 인증용 시크릿 (임의 문자열)
REVALIDATION_SECRET=your-secret-here
